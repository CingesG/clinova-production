NODE_ENV=development
PORT=4000

# PostgreSQL — өөрийн холболтын мөрийг оруулна
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Урт санамсаргүй string (production-д заавал солино)
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_ACCESS_EXPIRES_IN=30m
REFRESH_TOKEN_DAYS=14

# Фронтын URL (trailing slashгүй)
FRONTEND_URL=http://localhost:3164
CORS_ORIGIN=http://localhost:3164
ALLOW_LEGACY_DEV_CORS=true
ALLOW_NGROK=false

# Admin — эхний эхний удаа л ашиглагдана (хэрэглэгч байхгүй бол). Одоо байгаа admin-ийн нууцыг өөрчлөхгүй.
# И-мэйлийг production-д өөрчлөхгүй үлдээнэ.
DEFAULT_ADMIN_EMAIL=chinges_chinges@icloud.com
DEFAULT_ADMIN_PASSWORD=YourAdminPassword12chars

# Нэг удаагийн demo өвчтөн/нэг demo эмчийг app асаахад үүсгэх (ихэвчлэн false). Эмчүүдийг prisma seed-ээр л үүсгэнэ.
SEED_DEMO_ACCOUNTS_ON_BOOT=false

# Өвчтөн: имэйл баталгаажуулалт
REGISTER_SKIP_EMAIL_VERIFICATION=false

# Өвчтөн шууд нууцаар нэвтрэх (dev-only; production-д ихэвчлэн false)
ALLOW_DIRECT_PATIENT_PASSWORD_LOGIN=false

# Админ/эмч/ажилтан зөвхөн нууцаар нэвтрэх (2FA OTPгүй). Эмнэлгийн ажиллагаанд ихэвчлэн true.
ALLOW_PASSWORD_ONLY_STAFF_LOGIN=true

APP_NAME=Clinova
APP_LOGO_URL=
APP_LOGO_PATH=

EMAIL_DEBUG=false
OTP_DEBUG=false

# Илгээмж: resend | smtp
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=Clinova <onboarding@resend.dev>

# Gmail SMTP (зөвхөн EMAIL_PROVIDER=smtp үед; App Password ашиглана)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.address@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=Clinova <your.address@gmail.com>

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Зөвхөн dev / засвар — production-д хоосон үлдээнэ
EMAIL_TEST_SECRET=
MAINTENANCE_SECRET=

# Demo өвчтөн/нэг эмч (зөвхөн SEED_DEMO_ACCOUNTS_ON_BOOT=true бол bootstrap дээр)
DEMO_PATIENT_EMAIL=demo.patient@clinova.local
DEMO_PATIENT_PASSWORD=ClinovaPatient123!
DEMO_DOCTOR_EMAIL=demo.doctor@clinova.local
DEMO_DOCTOR_PASSWORD=ClinovaDoctor123!

# prisma/seed.ts — бүх 10 эмчид ижил нууц өгөх (local/demo). Хоосон бол эмч бүрт санамсаргүй нууц үүсгэгдэнэ (файлд бичигдэнэ).
# Production seed-д давтан ажиллуулахдаа нууц солих бол энэ хувьсагчаар rotate хийнэ.
DEMO_DOCTOR_PASSWORD=

# Local-only: `npm run credentials:demo` — gitignored `seed-output/login-credentials.local.*`
# Production NODE_ENV=production дээр заавал: ALLOW_DEMO_CREDENTIAL_EXPORT=true
ALLOW_DEMO_CREDENTIAL_EXPORT=false
RESET_ADMIN_PASSWORD_FOR_DEMO=false
RESET_DOCTOR_PASSWORDS_FOR_DEMO=false
RESET_DEMO_PATIENT_PASSWORDS=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_CHAT_TEMPERATURE=0.78
OPENAI_MAX_OUTPUT_TOKENS=3072
AI_AGENT_MAX_IMAGES=4
AI_AGENT_MAX_IMAGE_MB=12

STRIPE_SECRET_KEY=

# Google Sign-In — Web OAuth client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=
