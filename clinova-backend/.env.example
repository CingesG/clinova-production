NODE_ENV=production
PORT=4000

DATABASE_URL=ЧИНИЙ_RENDER_POSTGRES_INTERNAL_DATABASE_URL

JWT_SECRET=clinova-prod-jwt-secret-change-this-to-long-random-string-2026
JWT_ACCESS_EXPIRES_IN=30m
REFRESH_TOKEN_DAYS=14

FRONTEND_URL=https://clinova-production.vercel.app
CORS_ORIGIN=https://clinova-production.vercel.app
ALLOW_LEGACY_DEV_CORS=false
ALLOW_NGROK=false
ALLOW_DIRECT_PATIENT_PASSWORD_LOGIN=false
REGISTER_SKIP_EMAIL_VERIFICATION=false

APP_NAME=Clinova
APP_LOGO_URL=
APP_LOGO_PATH=

EMAIL_DEBUG=false
OTP_DEBUG=false

# Production (Render): EMAIL_PROVIDER=resend + RESEND_* (HTTPS). Local: EMAIL_PROVIDER=smtp + Gmail/SMTP below.
EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM=Clinova <onboarding@resend.dev>

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Clinova <you@gmail.com>

# Legacy aliases (optional; MailerService accepts these if SMTP_* unset)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=Clinova <you@gmail.com>

EMAIL_TEST_SECRET=clinova-email-test-secret-2026-change-this

DEFAULT_ADMIN_EMAIL=admin@clinova.mn
DEFAULT_ADMIN_PASSWORD=ClinovaAdmin123!

DEMO_PATIENT_EMAIL=demo.patient@clinova.mn
DEMO_PATIENT_PASSWORD=ClinovaPatient123!

DEMO_DOCTOR_EMAIL=demo.doctor@clinova.mn
DEMO_DOCTOR_PASSWORD=ClinovaDoctor123!

OPENAI_API_KEY=sk-proj-1234567890
OPENAI_MODEL=gpt-4o-mini
OPENAI_CHAT_TEMPERATURE=0.78
OPENAI_MAX_OUTPUT_TOKENS=3072
AI_AGENT_MAX_IMAGES=4
AI_AGENT_MAX_IMAGE_MB=12

STRIPE_SECRET_KEY=

GOOGLE_CLIENT_ID=ЧИНИЙ_GOOGLE_WEB_CLIENT_ID
GOOGLE_CLIENT_IDS=ЧИНИЙ_GOOGLE_WEB_CLIENT_ID