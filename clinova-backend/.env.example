# Copy to .env (never commit .env). Production: set values only in hosting → Environment Variables.
# Хуучин OpenAI / Gmail / JWT key-уудыг Git/чатад илгээсэн бол заавал revoke/шинээр солино.

NODE_ENV=development
PORT=4000

# PostgreSQL (prod: Render / Neon / Supabase-аас өгөгдсөн connection string)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/clinova

JWT_SECRET=replace-with-long-random-secret
JWT_ACCESS_EXPIRES_IN=30m
REFRESH_TOKEN_DAYS=14

# Вэб клиентийн URL (trailing slash байхгүй). Продакшн: Vercel domain.
# Жишээ: https://clinova.vercel.app эсвэл https://clinova.mn
FRONTEND_URL=http://localhost:3164

# Нэмэлт зөвшөөрөгдсөн origin-ууд (товхоолсон). www болон apex хоёуланг нэмнэ.
# Жишээ: https://clinova.mn,https://www.clinova.mn
CORS_ORIGIN=

# Продакшн дээр localhost/ngrok зөвшөөрөх (зөвхөн түр шалгалт). Үндсэнд false үлдээнэ.
ALLOW_LEGACY_DEV_CORS=false

# Зөвхөн dev: ngrok origin-уудыг зөвшөөрнө
ALLOW_NGROK=false

# trycloudflare tunnel (default: зөвшөөрнө dev-д). Бүрэн унтраах: ALLOW_TRYCLOUDFLARE=false
# ALLOW_TRYCLOUDFLARE=false

# Dev convenience: patient logs in with email+password only (no 6-digit login OTP).
ALLOW_DIRECT_PATIENT_PASSWORD_LOGIN=false
# Dev convenience: register returns tokens without inbox OTP. Production: false
REGISTER_SKIP_EMAIL_VERIFICATION=false

APP_NAME=Clinova
APP_LOGO_URL=
APP_LOGO_PATH=

# true: SMTP алдаа/тохируулгагүй тохиолдолд API response-д `debugCode`-оор OTP харагдана (prod-д false).
EMAIL_DEBUG=false
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Seed / demo (prod: хүчтэй нууц үг эсвэл seed хориглох)
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=ChangeMe_Strong_Password_1
DEMO_PATIENT_EMAIL=demo.patient@example.com
DEMO_PATIENT_PASSWORD=ChangeMe_Demo_1
DEMO_DOCTOR_EMAIL=demo.doctor@example.com
DEMO_DOCTOR_PASSWORD=ChangeMe_Demo_2

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_CHAT_TEMPERATURE=0.78
OPENAI_MAX_OUTPUT_TOKENS=3072
AI_AGENT_MAX_IMAGES=4
AI_AGENT_MAX_IMAGE_MB=12

# Stripe: production live key (sk_live_...) — тест түлхүүр repo-д битгий хадгална
STRIPE_SECRET_KEY=

# Google OAuth: id_token-ийн `aud` нь дорх client ID-уудыг дор хаяж нэгтэй таарах ёстой.
# Ихэвчлэн Backend + Flutter вэб дээр хоёуландаа **Web Application** client ID ашиглана.
# Олон client (Web + Android + iOS OAuth client ID): товхойлж нэмнэ.
GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_IDS=web-id.apps.googleusercontent.com,android-id.apps.googleusercontent.com
GOOGLE_CLIENT_IDS=

# SMTP: Gmail ашигласан 2FA заавал → "App password"-аар SMTP_PASS бөглөнө.
# И-мэйлт удааж/спамд орох тохиолдолд SendGrid / Resend / Mailgun зэргийг ашиглана.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

